# SmartInv — environment template.
#
# Copy to `.env` and fill in any secrets locally. `.env` is gitignored and
# must NEVER be committed. Keep real secrets (e.g. Langfuse keys) only in
# your local `.env`, never in this template.
#
#   cp .env.example .env

# --- Core ---
SMARTINV_ENVIRONMENT=dev

# --- Postgres (CV1.E4 / ADR-004, CV1.E6 / ADR-020) ---
# Runtime uses the least-privilege app role (RLS applies); migrations use admin.
SMARTINV_DATABASE_URL=postgresql://smartinv_app:smartinv_app@localhost:5432/smartinv
SMARTINV_ADMIN_DATABASE_URL=postgresql://smartinv:smartinv@localhost:5432/smartinv

# --- Redis (CV1.E4 / ADR-004) ---
SMARTINV_REDIS_URL=redis://localhost:6379/0

# --- Object store: SeaweedFS S3-compatible (CV1.E4 / ADR-017) ---
SMARTINV_S3_ENDPOINT_URL=http://localhost:8333
SMARTINV_S3_ACCESS_KEY=smartinv
SMARTINV_S3_SECRET_KEY=smartinvsecret
SMARTINV_S3_REGION=us-east-1
SMARTINV_S3_BUCKET=smartinv-local

# --- LLM observability: Langfuse Cloud free tier (CV1.E4 / ADR-018) ---
# Wired into the LLM gateway in CV5.E1. Leave the keys blank here; set the
# real values only in your local `.env`. Get keys at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# --- Identity: dev token-issuer (CV1.E6 / ADR-021) ---
# Dev HS256 secret. NEVER use with real customer data — swap in a real IdP first.
SMARTINV_JWT_SECRET=dev-insecure-secret-change-me-0123456789
